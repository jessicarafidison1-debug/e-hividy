<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Détails de la commande</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    .order-container {
      max-width: 900px;
      margin: 2rem auto;
      padding: 0 1rem;
    }
    
    .order-header {
      background: white;
      padding: 2rem;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      margin-bottom: 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    
    .order-header h1 {
      margin: 0;
    }
    
    .status-badge {
      background-color: #d4edda;
      color: #155724;
      padding: 0.5rem 1rem;
      border-radius: 4px;
      font-weight: bold;
    }
    
    .info-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1.5rem;
      margin-bottom: 2rem;
    }
    
    .info-box {
      background: white;
      padding: 1.5rem;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }
    
    .info-box h3 {
      margin-top: 0;
      color: #333;
    }
    
    .info-item {
      margin-bottom: 1rem;
    }
    
    .info-label {
      font-weight: bold;
      color: #666;
      font-size: 0.9rem;
    }
    
    .info-value {
      color: #333;
      margin-top: 0.3rem;
    }
    
    .items-box {
      background: white;
      padding: 2rem;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      margin-bottom: 2rem;
    }
    
    .items-table {
      width: 100%;
      border-collapse: collapse;
    }
    
    .items-table th,
    .items-table td {
      padding: 1rem;
      text-align: left;
      border-bottom: 1px solid #ddd;
    }
    
    .items-table th {
      background-color: #f9f9f9;
      font-weight: bold;
    }
    
    .summary-box {
      background: white;
      padding: 2rem;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }
    
    .summary-row {
      display: flex;
      justify-content: space-between;
      padding: 0.8rem 0;
      border-bottom: 1px solid #ddd;
    }
    
    .summary-total {
      border-bottom: none;
      border-top: 2px solid #333;
      padding-top: 1rem;
      font-size: 1.3rem;
      font-weight: bold;
      color: #28a745;
    }
    
    .back-btn {
      background-color: #007bff;
      color: white;
      padding: 0.7rem 1.5rem;
      border-radius: 4px;
      text-decoration: none;
      display: inline-block;
      margin-bottom: 2rem;
    }
    
    .back-btn:hover {
      background-color: #0056b3;
    }
  </style>
</head>
<body>
  <nav>
    <div class="nav-brand">
      <a href="/">
        <img src="/images/logo.jpg" alt="Myeva creation" class="nav-logo">
      </a>
    </div>
    
    <div class="nav-search">
      <form action="/" method="GET">
        <input type="text" name="search" placeholder="Rechercher des produits..." value="<%= typeof search !== 'undefined' ? search : '' %>">
        <button type="submit">🔍</button>
      </form>
    </div>

    <button class="menu-toggle" onclick="toggleMenu()">☰</button>
    <ul id="navMenu">
      <li><a href="/">Accueil</a></li>
      <% if (user) { %>
        <li><a href="/user/account">Compte</a></li>
        <li><a href="/cart">Panier</a></li>
        <li><a href="/auth/logout">Déconnexion</a></li>
      <% } else { %>
        <li><a href="/auth/login-page">Connexion</a></li>
        <li><a href="/auth/register-page">Inscription</a></li>
      <% } %>
    </ul>
  </nav>

  <script>
    function toggleMenu() {
      const menu = document.getElementById('navMenu');
      menu.classList.toggle('active');
    }
  </script>

  <main>
    <div class="order-container">
      <a href="/user/account" class="back-btn">← Retourner au compte</a>
      
      <div class="order-header">
        <h1>Commande n°<%= order.id %></h1>
        <span class="status-badge"><%= order.status %></span>
      </div>

      <div class="info-grid">
        <div class="info-box">
          <h3>Date de la commande</h3>
          <div class="info-item">
            <div class="info-value"><%= new Date(order.created_at).toLocaleString('fr-FR') %></div>
          </div>
        </div>
        <div class="info-box">
          <h3>Montant total</h3>
          <div class="info-item">
            <div class="info-value" style="font-size: 1.5rem; color: #28a745;">
              Ar<%= parseFloat(order.total_amount).toFixed(2) %>
            </div>
          </div>
        </div>
        <div class="info-box">
          <h3>Adresse de livraison</h3>
          <div class="info-item">
            <div class="info-value">
              <%= order.address %><br>
              <%= order.city %>, <%= order.state %> <%= order.zip %>
            </div>
          </div>
        </div>
      </div>

      <div class="items-box">
        <h2>Articles de la commande</h2>
        <% if (items.length > 0) { %>
          <table class="items-table">
            <thead>
              <tr>
                <th>Produit</th>
                <th>Quantité</th>
                <th>Prix unitaire</th>
                <th>Sous-total</th>
              </tr>
            </thead>
            <tbody>
              <% items.forEach(item => { %>
                <tr>
                  <td><strong><%= item.name %></strong></td>
                  <td><%= item.quantity %></td>
                  <td>Ar<%= parseFloat(item.price).toFixed(2) %></td>
                  <td>Ar<%= (parseFloat(item.price) * item.quantity).toFixed(2) %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        <% } else { %>
          <p>Aucun article dans cette commande.</p>
        <% } %>
      </div>

      <div class="summary-box">
        <h2>Résumé de la commande</h2>
        <div class="summary-row">
          <span>Sous-total :</span>
          <span>Ar<%= items.reduce((sum, item) => sum + (parseFloat(item.price) * item.quantity), 0).toFixed(2) %></span>
        </div>
        <div class="summary-row summary-total">
          <span>Total :</span>
          <span>Ar<%= parseFloat(order.total_amount).toFixed(2) %></span>
        </div>
      </div>
    </div>
  </main>

  <footer>
    <p>&copy; 2026 Shop. Tous droits réservés.</p>
  </footer>
</body>
</html>
