<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Détails de la commande</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    .order-container {
      max-width: 900px;
      margin: 2rem auto;
      padding: 0 1rem;
    }
    
    .order-header {
      background: white;
      padding: 2rem;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      margin-bottom: 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    
    .order-header h1 {
      margin: 0;
    }
    
    .status-badge {
      background-color: #d4edda;
      color: #155724;
      padding: 0.5rem 1rem;
      border-radius: 4px;
      font-weight: bold;
    }
    
    .info-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1.5rem;
      margin-bottom: 2rem;
    }
    
    .info-box {
      background: white;
      padding: 1.5rem;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }
    
    .info-box h3 {
      margin-top: 0;
      color: #333;
    }
    
    .info-item {
      margin-bottom: 1rem;
    }
    
    .info-label {
      font-weight: bold;
      color: #666;
      font-size: 0.9rem;
    }
    
    .info-value {
      color: #333;
      margin-top: 0.3rem;
    }
    
    .items-box {
      background: white;
      padding: 2rem;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      margin-bottom: 2rem;
    }
    
    .items-table {
      width: 100%;
      border-collapse: collapse;
    }
    
    .items-table th,
    .items-table td {
      padding: 1rem;
      text-align: left;
      border-bottom: 1px solid #ddd;
    }
    
    .items-table th {
      background-color: #f9f9f9;
      font-weight: bold;
    }
    
    .summary-box {
      background: white;
      padding: 2rem;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }
    
    .summary-row {
      display: flex;
      justify-content: space-between;
      padding: 0.8rem 0;
      border-bottom: 1px solid #ddd;
    }
    
    .summary-total {
      border-bottom: none;
      border-top: 2px solid #333;
      padding-top: 1rem;
      font-size: 1.3rem;
      font-weight: bold;
      color: #28a745;
    }
    
    .back-btn {
      background-color: #007bff;
      color: white;
      padding: 0.7rem 1.5rem;
      border-radius: 4px;
      text-decoration: none;
      display: inline-block;
      margin-bottom: 2rem;
    }
    
    .back-btn:hover {
      background-color: #0056b3;
    }
  </style>
</head>
<body>
  <nav>
    <div class="nav-brand">
      <a href="/">
        <img src="/images/logo.jpg" alt="Myeva creation" class="nav-logo">
      </a>
    </div>
    
    <div class="nav-search">
      <form action="/" method="GET">
        <input type="text" name="search" placeholder="Rechercher des produits..." value="<%= typeof search !== 'undefined' ? search : '' %>">
        <button type="submit">🔍</button>
      </form>
    </div>

    <button class="menu-toggle" onclick="toggleMenu()">☰</button>
    <ul id="navMenu">
      <li><a href="/">Accueil</a></li>
      <% if (user) { %>
        <li><a href="/user/account">Compte</a></li>
        <li><a href="/cart">Panier</a></li>
        <li><a href="/auth/logout">Déconnexion</a></li>
      <% } else { %>
        <li><a href="/auth/login-page">Connexion</a></li>
        <li><a href="/auth/register-page">Inscription</a></li>
      <% } %>
    </ul>
  </nav>

  <script>
    function toggleMenu() {
      const menu = document.getElementById('navMenu');
      menu.classList.toggle('active');
    }
  </script>

  <main>
    <div class="order-container">
      <a href="/user/account" class="back-btn">← Retourner au compte</a>

      <div class="order-header">
        <h1>Commande n°<%= order.id %></h1>
        <%
          const statusMap = {
            'pending': { class: 'status-pending', label: 'En attente de validation', icon: '⏳' },
            'completed': { class: 'status-completed', label: 'Validée', icon: '✅' },
            'cancelled': { class: 'status-cancelled', label: 'Annulée', icon: '❌' },
            'processing': { class: 'status-processing', label: 'En traitement', icon: '📦' },
            'shipped': { class: 'status-shipped', label: 'Expédiée', icon: '🚚' },
            'failed': { class: 'status-failed', label: 'Échouée', icon: '⚠️' }
          };
          const statusInfo = statusMap[order.status] || { class: '', label: order.status, icon: '📄' };
        %>
        <span class="status-badge <%= statusInfo.class %>"><%= statusInfo.icon %> <%= statusInfo.label %></span>
      </div>

      <% if (order.status === 'pending') { %>
        <div class="order-actions" style="margin-bottom: 2rem; display: flex; gap: 1rem; justify-content: flex-end;">
          <button onclick="cancelOrder()" class="btn-cancel-order" style="background-color: #dc3545; color: white; padding: 0.7rem 1.5rem; border: none; border-radius: 4px; cursor: pointer; font-size: 1rem;">
            ❌ Annuler la commande
          </button>
        </div>
      <% } %>

      <% if (order.status === 'pending') { %>
        <div class="alert alert-warning" style="margin-bottom: 2rem; padding: 1rem; background: #fff3cd; border: 1px solid #ffc107; border-radius: 8px; color: #856404;">
          <strong>⏳ Commande en attente :</strong> Votre commande est en cours de validation par notre équipe. Vous recevrez une notification une fois qu'elle sera validée.
        </div>
      <% } else if (order.status === 'completed') { %>
        <div class="alert alert-success" style="margin-bottom: 2rem; padding: 1rem; background: #d4edda; border: 1px solid #28a745; border-radius: 8px; color: #155724;">
          <strong>✅ Commande validée :</strong> Votre commande a été validée et est en cours de préparation.
        </div>
      <% } else if (order.status === 'cancelled') { %>
        <div class="alert alert-danger" style="margin-bottom: 2rem; padding: 1rem; background: #f8d7da; border: 1px solid #dc3545; border-radius: 8px; color: #721c24;">
          <strong>❌ Commande annulée :</strong> Votre commande a été annulée. Les produits ont été remis en stock.
        </div>
      <% } %>

      <div class="info-grid">
        <div class="info-box">
          <h3>Date de la commande</h3>
          <div class="info-item">
            <div class="info-value"><%= new Date(order.created_at).toLocaleString('fr-FR') %></div>
          </div>
        </div>
        <div class="info-box">
          <h3>Montant total</h3>
          <div class="info-item">
            <div class="info-value" style="font-size: 1.5rem; color: #28a745;">
              Ar<%= parseFloat(order.total_amount).toFixed(2) %>
            </div>
          </div>
        </div>
        <div class="info-box">
          <h3>Adresse de livraison</h3>
          <div class="info-item">
            <div class="info-value">
              <%= order.address %><br>
              <%= order.city %>, <%= order.state %> <%= order.zip %>
            </div>
          </div>
        </div>
        <div class="info-box">
          <h3>Téléphone</h3>
          <div class="info-item">
            <div class="info-value" style="font-weight: bold; color: #007bff;">
              <%= order.phone || 'N/A' %>
            </div>
          </div>
        </div>
      </div>

      <div class="items-box">
        <h2>Articles de la commande</h2>
        <% if (items.length > 0) { %>
          <table class="items-table">
            <thead>
              <tr>
                <th>Produit</th>
                <th>Quantité</th>
                <th>Prix unitaire</th>
                <th>Sous-total</th>
              </tr>
            </thead>
            <tbody>
              <% items.forEach(item => { %>
                <tr>
                  <td><strong><%= item.name %></strong></td>
                  <td><%= item.quantity %></td>
                  <td>Ar<%= parseFloat(item.price).toFixed(2) %></td>
                  <td>Ar<%= (parseFloat(item.price) * item.quantity).toFixed(2) %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        <% } else { %>
          <p>Aucun article dans cette commande.</p>
        <% } %>
      </div>

      <div class="summary-box">
        <h2>Résumé de la commande</h2>
        <div class="summary-row">
          <span>Sous-total :</span>
          <span>Ar<%= items.reduce((sum, item) => sum + (parseFloat(item.price) * item.quantity), 0).toFixed(2) %></span>
        </div>
        <div class="summary-row summary-total">
          <span>Total :</span>
          <span>Ar<%= parseFloat(order.total_amount).toFixed(2) %></span>
        </div>
      </div>

      <!-- Order Timeline -->
      <div class="timeline-box" style="margin-top: 2rem;">
        <h2>Chronologie de la commande</h2>
        <div class="timeline">
          <div class="timeline-item active">
            <div class="timeline-dot">🛍️</div>
            <div class="timeline-content">
              <div class="timeline-title">Commande passée</div>
              <div class="timeline-date"><%= new Date(order.created_at).toLocaleString('fr-FR') %></div>
              <div class="timeline-description">Votre commande a été créée avec succès</div>
            </div>
          </div>
          <% if (order.status !== 'pending') { %>
          <div class="timeline-item active">
            <div class="timeline-dot">✅</div>
            <div class="timeline-content">
              <div class="timeline-title">Commande validée</div>
              <div class="timeline-date">Validée par l'administrateur</div>
              <div class="timeline-description">Votre commande a été confirmée</div>
            </div>
          </div>
          <% } %>
          <% if (order.status === 'completed' || order.status === 'processing' || order.status === 'shipped') { %>
          <div class="timeline-item active">
            <div class="timeline-dot">📦</div>
            <div class="timeline-content">
              <div class="timeline-title">En traitement</div>
              <div class="timeline-date">Commande en préparation</div>
              <div class="timeline-description">Articles prélevés et emballés</div>
            </div>
          </div>
          <% } %>
          <% if (order.status === 'shipped' || order.status === 'completed') { %>
          <div class="timeline-item active">
            <div class="timeline-dot">🚚</div>
            <div class="timeline-content">
              <div class="timeline-title">Expédiée</div>
              <div class="timeline-date">Commande en transit</div>
              <div class="timeline-description">En route vers vous</div>
            </div>
          </div>
          <% } %>
          <% if (order.status === 'completed') { %>
          <div class="timeline-item active">
            <div class="timeline-dot">✓</div>
            <div class="timeline-content">
              <div class="timeline-title">Livrée</div>
              <div class="timeline-date">Commande complétée</div>
              <div class="timeline-description">Vous avez reçu votre commande</div>
            </div>
          </div>
          <% } %>
          <% if (order.status === 'cancelled') { %>
          <div class="timeline-item active">
            <div class="timeline-dot">❌</div>
            <div class="timeline-content">
              <div class="timeline-title">Annulée</div>
              <div class="timeline-date">Commande annulée</div>
              <div class="timeline-description">La commande a été annulée</div>
            </div>
          </div>
          <% } %>
        </div>
      </div>
    </div>
  </main>

  <footer>
    <p>&copy; 2026 Shop. Tous droits réservés.</p>
  </footer>

  <style>
    .timeline-box {
      background: white;
      padding: 2rem;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    .timeline-box h2 {
      margin-bottom: 1.5rem;
      color: #333;
    }

    .timeline {
      position: relative;
      padding-left: 2rem;
    }

    .timeline-item {
      position: relative;
      padding-bottom: 2rem;
      padding-left: 1.5rem;
      border-left: 2px solid #e0e0e0;
    }

    .timeline-item:last-child {
      padding-bottom: 0;
      border-left-color: transparent;
    }

    .timeline-item.active {
      border-left-color: #28a745;
    }

    .timeline-dot {
      position: absolute;
      left: -2.375rem;
      top: 0;
      width: 2.5rem;
      height: 2.5rem;
      background: #f8f9fa;
      border: 2px solid #e0e0e0;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.25rem;
      z-index: 1;
    }

    .timeline-item.active .timeline-dot {
      background: #28a745;
      border-color: #28a745;
    }

    .timeline-content {
      background: #f8f9fa;
      padding: 1rem;
      border-radius: 8px;
    }

    .timeline-title {
      font-weight: bold;
      color: #333;
      margin-bottom: 0.25rem;
    }

    .timeline-date {
      font-size: 0.875rem;
      color: #666;
      margin-bottom: 0.5rem;
    }

    .timeline-description {
      font-size: 0.875rem;
      color: #555;
      background: white;
      padding: 0.5rem 0.75rem;
      border-radius: 4px;
      display: inline-block;
    }

    .btn-cancel-order:hover {
      background-color: #c82333 !important;
    }
  </style>

  <script>
    function cancelOrder() {
      const reason = prompt('Veuillez entrer la raison de l\'annulation (optionnel) :');
      if (reason === null) return;

      if (!confirm('Êtes-vous sûr de vouloir annuler cette commande ?\nLes produits seront remis en stock.')) return;

      fetch('/user/order/<%= order.id %>/cancel', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ orderId: <%= order.id %>, reason: reason || '' })
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          alert('❌ Commande #' + <%= order.id %> + ' annulée avec succès !\nLes produits ont été remis en stock.');
          window.location.reload();
        } else {
          alert('Erreur: ' + data.message);
        }
      })
      .catch(err => {
        console.error('Cancel error:', err);
        alert('❌ Erreur lors de l\'annulation de la commande: ' + err.message);
      });
    }
  </script>
</body>
</html>
