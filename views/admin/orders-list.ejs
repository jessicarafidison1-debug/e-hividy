<%- include('partials/head', { title: 'Commandes' }) %>
<%- include('partials/sidebar', { activePage: 'orders' }) %>

<main class="admin-main">
  <div class="page-header">
    <div>
      <h1>Commandes</h1>
      <p class="text-muted" style="margin: 0.25rem 0 0 0; font-size: 0.9375rem;">Suivre et gérer les commandes des clients</p>
    </div>
    <div class="page-header-actions">
      <button class="admin-btn admin-btn-secondary" onclick="window.print()">
        Imprimer
      </button>
    </div>
  </div>

  <!-- Carte des commandes -->
  <div class="card">
    <div class="card-body" style="padding: 0;">
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-error" style="margin: 1.5rem;">
          <%= error %>
        </div>
      <% } %>

      <% if (orders && orders.length > 0) { %>
        <!-- Résumé des commandes -->
        <div class="orders-summary">
          <div class="summary-item">
            <div class="summary-content">
              <span class="summary-label">Commandes totales</span>
              <span class="summary-value"><%= orders.length %></span>
            </div>
          </div>
          <div class="summary-item">
            <div class="summary-content">
              <span class="summary-label">Completées</span>
              <span class="summary-value"><%= orders.filter(o => o.status === 'completed').length %></span>
            </div>
          </div>
          <div class="summary-item">
            <div class="summary-content">
              <span class="summary-label">En attente</span>
              <span class="summary-value"><%= orders.filter(o => o.status === 'pending').length %></span>
            </div>
          </div>
          <div class="summary-item">
            <div class="summary-content">
              <span class="summary-label">En traitement</span>
              <span class="summary-value"><%= orders.filter(o => ['processing', 'shipped'].includes(o.status)).length %></span>
            </div>
          </div>
          <div class="summary-item">
            <div class="summary-content">
              <span class="summary-label">Annulées</span>
              <span class="summary-value"><%= orders.filter(o => ['cancelled', 'failed'].includes(o.status)).length %></span>
            </div>
          </div>
          <div class="summary-item highlight">
            <div class="summary-content">
              <span class="summary-label">Revenu total</span>
              <span class="summary-value text-success">Ar<%= orders.reduce((sum, o) => sum + parseFloat(o.total_amount || 0), 0).toFixed(2) %></span>
            </div>
          </div>
        </div>

        <div class="table-responsive">
          <table class="table">
            <thead>
              <tr>
                <th style="width: 90px;">ID de commande</th>
                <th>Client</th>
                <th style="width: 130px;">Montant</th>
                <th style="width: 130px;">Statu</th>
                <th style="width: 150px;">Date et heure</th>
                <th style="width: 80px; text-align: right;">Action</th>
              </tr>
            </thead>
            <tbody>
              <% orders.forEach(order => { %>
                <tr>
                  <td>
                    <span class="order-id">#<%= order.id %></span>
                  </td>
                  <td>
                    <div class="customer-info">
                      <div class="customer-name">
                        <span class="font-semibold"><%= order.customer_name %></span>
                      </div>
                      <div class="customer-email">
                        <%= order.email %>
                      </div>
                      <div class="customer-phone">
                        <i data-lucide="phone" style="width: 12px; height: 12px;"></i>
                        <%= order.phone || 'N/A' %>
                      </div>
                    </div>
                  </td>
                  <td>
                    <span class="order-amount">Ar<%= parseFloat(order.total_amount).toFixed(2) %></span>
                  </td>
                  <td>
                    <%
                      const statusMap = {
                        'completed': { class: 'status-completed', label: 'Completée' },
                        'pending': { class: 'status-pending', label: 'En attente' },
                        'processing': { class: 'status-processing', label: 'En traitement' },
                        'shipped': { class: 'status-shipped', label: 'Expédiée' },
                        'cancelled': { class: 'status-cancelled', label: 'Annulée' },
                        'failed': { class: 'status-failed', label: 'Échouée' }
                      };
                      const statusInfo = statusMap[order.status] || { class: '', label: order.status };
                    %>
                    <span class="status-badge <%= statusInfo.class %>">
                      <%= statusInfo.label %>
                    </span>
                  </td>
                  <td>
                    <div class="datetime-cell">
                      <span class="order-date"><%= formatDate(order.created_at) %></span>
                      <span class="order-time"><%= formatTime(order.created_at) %></span>
                    </div>
                  </td>
                  <td>
                    <div class="action-buttons" style="justify-content: flex-end;">
                      <a href="/admin/orders/<%= order.id %>" class="btn-action btn-action-view" title="Voir les détails">
                        Voir
                      </a>
                    </div>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="empty-state">
          <h3>Aucune commande pour le moment</h3>
          <p>Les commandes apparaîtront ici une fois que les clients commenceront à faire des achats</p>
          <a href="/admin/dashboard" class="admin-btn">
            Voir le tableau de bord
          </a>
        </div>
      <% } %>
    </div>
  </div>
</main>

<style>
  .orders-summary {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    background: linear-gradient(180deg, var(--gray-50) 0%, var(--white) 100%);
    border-bottom: 1px solid var(--gray-200);
  }

  .summary-item {
    display: flex;
    align-items: center;
    padding: 1rem;
    background: var(--white);
    border-radius: var(--radius-xl);
    border: 1px solid var(--gray-200);
    box-shadow: var(--shadow-xs);
    transition: var(--transition);
  }

  .summary-item:hover {
    box-shadow: var(--shadow-sm);
    transform: translateY(-2px);
  }

  .summary-item.highlight {
    border-color: var(--success);
    background: linear-gradient(135deg, var(--white), var(--success-light));
  }

  .summary-content {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .summary-label {
    font-size: 0.75rem;
    color: var(--gray-500);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
  }

  .summary-value {
    font-size: 1.375rem;
    font-weight: 800;
    color: var(--gray-900);
    line-height: 1;
  }

  .order-id {
    font-weight: 700;
    color: var(--primary);
    font-size: 0.9375rem;
  }

  .customer-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .customer-name {
    display: flex;
    align-items: center;
    font-size: 0.9375rem;
  }

  .customer-email {
    font-size: 0.8125rem;
    color: var(--gray-500);
    display: flex;
    align-items: center;
  }

  .customer-phone {
    font-size: 0.8125rem;
    color: var(--primary);
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-top: 0.25rem;
  }

  .customer-phone i {
    width: 12px;
    height: 12px;
    color: var(--primary);
  }

  .order-amount {
    font-weight: 700;
    color: var(--gray-900);
    font-size: 1rem;
    background: var(--gray-50);
    padding: 0.375rem 0.75rem;
    border-radius: var(--radius);
    display: inline-block;
  }

  .datetime-cell {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .order-date {
    font-size: 0.875rem;
    color: var(--gray-700);
    font-weight: 500;
  }

  .order-time {
    font-size: 0.75rem;
    color: var(--gray-500);
  }

  @media (max-width: 1024px) {
    .orders-summary {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .orders-summary {
      grid-template-columns: repeat(2, 1fr);
    }

    .summary-item {
      padding: 0.75rem;
    }

    .summary-value {
      font-size: 1.125rem;
    }
  }
</style>

<%- include('partials/footer') %>
<%- include('partials/scripts') %>
