<%- include('partials/head', { title: 'Demande #' + request.id }) %>
<%- include('partials/sidebar', { activePage: 'order-requests' }) %>

<main class="admin-main">
  <div class="page-header">
    <div class="header-with-status">
      <h1 class="m-0">
        <i data-lucide="file-check"></i> Demande #<%= request.id %>
      </h1>
      <%
        const statusMap = {
          'completed': { icon: 'check-circle', class: 'status-completed', label: 'Completée' },
          'pending': { icon: 'clock', class: 'status-pending', label: 'En attente' },
          'approved': { icon: 'thumbs-up', class: 'status-approved', label: 'Approuvée - En attente validation admin' },
          'cancelled': { icon: 'x-circle', class: 'status-cancelled', label: 'Annulée' }
        };
        const statusInfo = statusMap[request.status] || { icon: 'file-text', class: '', label: request.status };
      %>
      <span class="status-badge <%= statusInfo.class %> status-badge-lg">
        <i data-lucide="<%= statusInfo.icon %>"></i>
        <%= statusInfo.label %>
      </span>
    </div>
    <div class="page-header-actions">
      <% if (request.status === 'pending') { %>
        <button class="admin-btn admin-btn-success" onclick="approveRequest()">
          <i data-lucide="check"></i> Valider la demande
        </button>
        <button class="admin-btn admin-btn-danger" onclick="cancelRequest()">
          <i data-lucide="x"></i> Annuler la demande
        </button>
      <% } %>
      <button class="admin-btn admin-btn-secondary" onclick="window.print()">
        <i data-lucide="printer"></i> Imprimer
      </button>
      <a href="/admin/order-requests" class="admin-btn admin-btn-secondary">
        <i data-lucide="arrow-left"></i> Retour
      </a>
    </div>
  </div>

  <!-- Request Info Grid -->
  <div class="order-info-grid">
    <!-- Customer Information -->
    <div class="info-card">
      <div class="info-card-header">
        <h3><i data-lucide="user"></i> Informations sur le client</h3>
      </div>
      <div class="info-list">
        <div class="info-item">
          <span class="label">
            <i data-lucide="user" style="width: 14px; height: 14px; margin-right: 6px;"></i>
            Nom
          </span>
          <span class="value"><%= customer.name %></span>
        </div>
        <div class="info-item">
          <span class="label">
            <i data-lucide="mail" style="width: 14px; height: 14px; margin-right: 6px;"></i>
            Email
          </span>
          <span class="value"><%= customer.email %></span>
        </div>
        <div class="info-item">
          <span class="label">
            <i data-lucide="phone" style="width: 14px; height: 14px; margin-right: 6px;"></i>
            Téléphone
          </span>
          <span class="value phone-value"><%= request.phone || 'N/A' %></span>
        </div>
        <div class="info-item">
          <span class="label">
            <i data-lucide="map-pin" style="width: 14px; height: 14px; margin-right: 6px;"></i>
            Adresse de livraison
          </span>
          <span class="value address-value">
            <%= request.address %><br>
            <%= request.city %>,
            <%= request.state %>
            <%= request.zip %>
          </span>
        </div>
      </div>
    </div>

    <!-- Request Summary -->
    <div class="info-card">
      <div class="info-card-header">
        <h3><i data-lucide="info"></i> Détails de la demande</h3>
      </div>
      <div class="info-list">
        <div class="info-item">
          <span class="label">
            <i data-lucide="hash" style="width: 14px; height: 14px; margin-right: 6px;"></i>
            Numéro de demande
          </span>
          <span class="value order-id-large">#<%= request.id %></span>
        </div>
        <div class="info-item">
          <span class="label">
            <i data-lucide="calendar" style="width: 14px; height: 14px; margin-right: 6px;"></i>
            Soumise le
          </span>
          <span class="value">
            <span class="order-date-display"><%= formatDate(request.created_at) %></span>
            <span class="order-time-display"><%= formatTime(request.created_at) %></span>
          </span>
        </div>
        <div class="info-item">
          <span class="label">
            <i data-lucide="percent" style="width: 14px; height: 14px; margin-right: 6px;"></i>
            Réduction première commande
          </span>
          <span class="value">
            <% if (request.discount_percent > 0) { %>
              <span class="status-badge status-success"><%= request.discount_percent %>%</span>
            <% } else { %>
              <span class="status-badge status-secondary">0%</span>
            <% } %>
          </span>
        </div>
        <div class="info-item">
          <span class="label">
            <i data-lucide="dollar-sign" style="width: 14px; height: 14px; margin-right: 6px;"></i>
            Montant total
          </span>
          <span class="value total-amount">Ar<%= parseFloat(request.total_amount).toFixed(2) %></span>
        </div>
      </div>
    </div>
  </div>

  <!-- Request Items Card -->
  <div class="card mb-4">
    <div class="card-header">
      <h2><i data-lucide="shopping-cart"></i> Articles de la demande</h2>
      <span class="items-count"><%= items.length %> article<%= items.length !== 1 ? 's' : '' %></span>
    </div>
    <div class="card-body" style="padding: 0;">
      <% if (items && items.length > 0) { %>
        <div class="table-responsive">
          <table class="table">
            <thead>
              <tr>
                <th>Produit</th>
                <th style="width: 130px;">Prix unitaire</th>
                <th style="width: 100px; text-align: center;">Quantité</th>
                <th style="width: 130px; text-align: right;">Sous-total</th>
              </tr>
            </thead>
            <tbody>
              <% items.forEach(item => { %>
                <tr>
                  <td>
                    <div class="order-item-info">
                      <span class="item-name"><%= item.name %></span>
                      <span class="item-sku">SKU: #<%= item.product_id %></span>
                    </div>
                  </td>
                  <td>
                    <span class="item-price">Ar<%= parseFloat(item.price).toFixed(2) %></span>
                  </td>
                  <td>
                    <span class="item-quantity"><%= item.quantity %></span>
                  </td>
                  <td>
                    <span class="item-subtotal">Ar<%= (parseFloat(item.price) * item.quantity).toFixed(2) %></span>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>

        <div class="order-summary-box">
          <div class="summary-breakdown">
            <div class="summary-row">
              <span class="label">Sous-total (<%= items.length %> <%= items.length !== 1 ? 'articles' : 'article' %>)</span>
              <span class="value">Ar<%= items.reduce((sum, item) => sum + (parseFloat(item.price) * item.quantity), 0).toFixed(2) %></span>
            </div>
            <% const subtotal = items.reduce((sum, item) => sum + (parseFloat(item.price) * item.quantity), 0); %>
            <div class="summary-row">
              <span class="label">
                Réduction (<%= request.discount_percent %>%)
              </span>
              <span class="value text-success">- Ar<%= parseFloat(request.discount_amount).toFixed(2) %></span>
            </div>
            <div class="summary-row">
              <span class="label">
                Frais de livraison
                <% if (request.shipping_fee === 0) { %>
                  <span style="font-size: 0.75rem; color: var(--success); font-weight: 400; margin-left: 4px;">(Offert dès 200 000 Ar)</span>
                <% } %>
              </span>
              <span class="value <%= request.shipping_fee === 0 ? 'shipping-free' : 'shipping-fee' %>">
                <% if (request.shipping_fee === 0) { %>
                  <i data-lucide="gift"></i>
                  GRATUITE
                <% } else { %>
                  <i data-lucide="truck"></i>
                  Ar<%= parseFloat(request.shipping_fee).toFixed(2) %>
                <% } %>
              </span>
            </div>
            <div class="summary-row total">
              <span class="label">
                Total
                <span class="total-label-hint">Tous les impôts inclus</span>
              </span>
              <span class="value total-value">Ar<%= parseFloat(request.total_amount).toFixed(2) %></span>
            </div>
          </div>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Status Info -->
  <div class="card">
    <div class="card-header">
      <h2><i data-lucide="info"></i> Informations sur le statut</h2>
    </div>
    <div class="card-body">
      <div class="status-info-container">
        <% if (request.status === 'pending') { %>
          <div class="status-info-item">
            <div class="status-info-icon">
              <i data-lucide="clock"></i>
            </div>
            <div class="status-info-content">
              <h4>En attente de validation</h4>
              <p>Cette demande est en attente de validation par l'administrateur. Une fois approuvée, le client pourra passer sa commande.</p>
            </div>
          </div>
        <% } else if (request.status === 'approved') { %>
          <div class="status-info-item approved">
            <div class="status-info-icon">
              <i data-lucide="check-circle"></i>
            </div>
            <div class="status-info-content">
              <h4>Demande approuvée</h4>
              <p>Cette demande a été approuvée. Le client peut maintenant passer sa commande.</p>
              <% if (request.updated_at) { %>
                <p class="status-info-date">Approuvée le <%= formatDate(request.updated_at) %> à <%= formatTime(request.updated_at) %></p>
              <% } %>
            </div>
          </div>
        <% } else if (request.status === 'completed') { %>
          <div class="status-info-item completed">
            <div class="status-info-icon">
              <i data-lucide="check-circle"></i>
            </div>
            <div class="status-info-content">
              <h4>Demande complétée</h4>
              <p>Cette demande a été convertie en commande.</p>
            </div>
          </div>
        <% } else if (request.status === 'cancelled') { %>
          <div class="status-info-item cancelled">
            <div class="status-info-icon">
              <i data-lucide="x-circle"></i>
            </div>
            <div class="status-info-content">
              <h4>Demande annulée</h4>
              <p>Cette demande a été annulée par l'administrateur.</p>
              <% if (request.updated_at) { %>
                <p class="status-info-date">Annulée le <%= formatDate(request.updated_at) %> à <%= formatTime(request.updated_at) %></p>
              <% } %>
            </div>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Timeline Card -->
  <div class="card">
    <div class="card-header">
      <h2><i data-lucide="history"></i> Chronologie de la demande</h2>
    </div>
    <div class="card-body">
      <div class="timeline-container">
        <div class="timeline-item active">
          <div class="timeline-dot">
            <i data-lucide="file-text"></i>
          </div>
          <div class="timeline-content">
            <div class="timeline-title">Demande soumise</div>
            <div class="timeline-date">
              <%= formatDate(request.created_at) %> à <%= formatTime(request.created_at) %>
            </div>
            <div class="timeline-description">Le client a soumis la demande</div>
          </div>
        </div>

        <% if (request.status === 'approved') { %>
        <div class="timeline-item active">
          <div class="timeline-dot">
            <i data-lucide="thumbs-up"></i>
          </div>
          <div class="timeline-content">
            <div class="timeline-title">Demande approuvée</div>
            <div class="timeline-date">
              <%= formatDate(request.updated_at) %> à <%= formatTime(request.updated_at) %>
            </div>
            <div class="timeline-description">L'administrateur a approuvé la demande</div>
          </div>
        </div>
        <% } %>

        <% if (request.status === 'completed') { %>
        <div class="timeline-item active">
          <div class="timeline-dot">
            <i data-lucide="check-circle"></i>
          </div>
          <div class="timeline-content">
            <div class="timeline-title">Demande complétée</div>
            <div class="timeline-date">Commande automatiquement créée</div>
            <div class="timeline-description">La commande a été générée et payée</div>
          </div>
        </div>
        <% } %>

        <% if (request.status === 'cancelled') { %>
        <div class="timeline-item active">
          <div class="timeline-dot">
            <i data-lucide="x-circle"></i>
          </div>
          <div class="timeline-content">
            <div class="timeline-title">Demande annulée</div>
            <div class="timeline-date">
              <%= formatDate(request.updated_at) %> à <%= formatTime(request.updated_at) %>
            </div>
            <div class="timeline-description">La demande a été annulée</div>
          </div>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</main>

<style>
  .header-with-status {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .status-badge-lg {
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
  }

  .status-badge-lg i {
    width: 14px;
    height: 14px;
  }

  .order-info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .info-card {
    background: var(--white);
    padding: 0;
    border-radius: var(--radius-xl);
    border: 1px solid var(--gray-200);
    box-shadow: var(--shadow);
    overflow: hidden;
    transition: var(--transition);
  }

  .info-card:hover {
    box-shadow: var(--shadow-md);
  }

  .info-card-header {
    padding: 1.25rem 1.5rem;
    background: linear-gradient(180deg, var(--gray-50) 0%, var(--white) 100%);
    border-bottom: 1px solid var(--gray-200);
  }

  .info-card-header h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--gray-900);
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin: 0;
  }

  .info-card-header h3 i {
    color: var(--primary);
    width: 18px;
    height: 18px;
  }

  .info-list {
    padding: 1.25rem 1.5rem;
  }

  .info-item {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    padding: 0.875rem 0;
    border-bottom: 1px solid var(--gray-100);
  }

  .info-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .info-item:first-child {
    padding-top: 0;
  }

  .info-item .label {
    color: var(--gray-500);
    font-weight: 500;
    font-size: 0.875rem;
    display: flex;
    align-items: center;
    white-space: nowrap;
  }

  .info-item .label i {
    color: var(--gray-400);
  }

  .info-item .value {
    font-weight: 600;
    color: var(--gray-800);
    text-align: right;
    font-size: 0.9375rem;
  }

  .address-value {
    max-width: 220px;
    line-height: 1.5;
  }

  .phone-value {
    font-weight: 700;
    color: var(--primary);
    font-size: 1rem;
    letter-spacing: 0.5px;
  }

  .order-id-large {
    font-size: 1.125rem;
    color: var(--primary);
  }

  .order-date-display {
    display: block;
    font-weight: 600;
  }

  .order-time-display {
    font-size: 0.8125rem;
    color: var(--gray-500);
  }

  .total-amount {
    font-size: 1.25rem;
    color: var(--success);
  }

  .items-count {
    font-size: 0.8125rem;
    color: var(--gray-500);
    background: var(--gray-100);
    padding: 0.375rem 0.75rem;
    border-radius: var(--radius-full);
  }

  .order-item-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .item-name {
    font-weight: 600;
    color: var(--gray-900);
    font-size: 0.9375rem;
  }

  .item-sku {
    font-size: 0.75rem;
    color: var(--gray-500);
  }

  .item-price {
    color: var(--gray-700);
    font-size: 0.9375rem;
  }

  .item-quantity {
    font-weight: 700;
    color: var(--gray-900);
    background: var(--gray-100);
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius);
    display: inline-block;
    text-align: center;
    min-width: 40px;
  }

  .item-subtotal {
    font-weight: 700;
    color: var(--gray-900);
    font-size: 1rem;
  }

  .order-summary-box {
    padding: 1.5rem;
    background: linear-gradient(180deg, var(--gray-50) 0%, var(--white) 100%);
    border-top: 1px solid var(--gray-200);
  }

  .summary-breakdown {
    max-width: 360px;
    margin-left: auto;
  }

  .summary-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
    color: var(--gray-600);
    font-size: 0.9375rem;
  }

  .summary-row .label {
    font-weight: 500;
  }

  .summary-row .value {
    font-weight: 600;
  }

  .shipping-fee {
    color: var(--warning);
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-weight: 700;
  }

  .shipping-fee i {
    width: 16px;
    height: 16px;
  }

  .shipping-free {
    color: var(--success);
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-weight: 700;
  }

  .shipping-free i {
    width: 16px;
    height: 16px;
  }

  .summary-row.total {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 2px solid var(--gray-300);
  }

  .summary-row.total .label {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .total-label-hint {
    font-size: 0.75rem;
    color: var(--gray-500);
    font-weight: 400;
    text-transform: none;
  }

  .summary-row.total .total-value {
    font-size: 1.5rem;
    color: var(--primary);
  }

  .status-approved {
    background-color: var(--success-light);
    color: var(--success);
    border: 1px solid var(--success);
  }

  /* Status Info */
  .status-info-container {
    padding: 0.5rem 0;
  }

  .status-info-item {
    display: flex;
    gap: 1.5rem;
    padding: 1.5rem;
    background: var(--gray-50);
    border-radius: var(--radius-xl);
    border-left: 4px solid var(--warning);
  }

  .status-info-item.approved {
    background: linear-gradient(135deg, rgba(40, 167, 69, 0.1) 0%, var(--gray-50) 100%);
    border-left-color: var(--success);
  }

  .status-info-item.completed {
    background: linear-gradient(135deg, rgba(40, 167, 69, 0.15) 0%, var(--gray-50) 100%);
    border-left-color: var(--success);
  }

  .status-info-item.cancelled {
    background: linear-gradient(135deg, rgba(220, 53, 69, 0.1) 0%, var(--gray-50) 100%);
    border-left-color: var(--danger);
  }

  .status-info-icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--white);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .status-info-item.approved .status-info-icon,
  .status-info-item.completed .status-info-icon {
    background: var(--success);
  }

  .status-info-item.cancelled .status-info-icon {
    background: var(--danger);
  }

  .status-info-icon i {
    width: 24px;
    height: 24px;
    color: var(--gray-600);
  }

  .status-info-item.approved .status-info-icon i,
  .status-info-item.completed .status-info-icon i {
    color: white;
  }

  .status-info-item.cancelled .status-info-icon i {
    color: white;
  }

  .status-info-content h4 {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--gray-900);
    margin: 0 0 0.5rem 0;
  }

  .status-info-content p {
    font-size: 0.9375rem;
    color: var(--gray-600);
    line-height: 1.6;
    margin: 0;
  }

  .status-info-date {
    font-size: 0.8125rem;
    color: var(--gray-500);
    margin-top: 0.75rem !important;
  }

  /* Timeline */
  .timeline-container {
    padding: 0.5rem 0;
  }

  .timeline-item {
    display: flex;
    gap: 1.25rem;
    padding-bottom: 1.75rem;
    position: relative;
  }

  .timeline-item::before {
    content: '';
    position: absolute;
    left: 15px;
    top: 32px;
    bottom: 0;
    width: 2px;
    background-color: var(--gray-200);
  }

  .timeline-item:last-child {
    padding-bottom: 0;
  }

  .timeline-item:last-child::before {
    display: none;
  }

  .timeline-dot {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background-color: var(--gray-200);
    border: 3px solid var(--white);
    box-shadow: 0 0 0 1px var(--gray-200);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition);
    z-index: 1;
  }

  .timeline-dot i {
    width: 14px;
    height: 14px;
    color: var(--gray-500);
  }

  .timeline-item.active .timeline-dot {
    background-color: var(--success);
    box-shadow: 0 0 0 3px var(--success-light);
  }

  .timeline-item.active .timeline-dot i {
    color: white;
  }

  .timeline-content {
    flex: 1;
    min-width: 0;
    padding-top: 0.25rem;
  }

  .timeline-title {
    font-weight: 700;
    font-size: 0.9375rem;
    color: var(--gray-800);
    margin-bottom: 0.25rem;
  }

  .timeline-date {
    font-size: 0.8125rem;
    color: var(--gray-500);
    margin-bottom: 0.375rem;
  }

  .timeline-description {
    font-size: 0.8125rem;
    color: var(--gray-600);
    background: var(--gray-50);
    padding: 0.5rem 0.75rem;
    border-radius: var(--radius);
    display: inline-block;
  }

  @media (max-width: 768px) {
    .order-info-grid {
      grid-template-columns: 1fr;
    }

    .header-with-status {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .page-header-actions {
      width: 100%;
    }

    .page-header-actions .admin-btn {
      flex: 1;
      justify-content: center;
    }

    .summary-breakdown {
      max-width: 100%;
    }

    .status-info-item {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>

<%- include('partials/footer') %>
<%- include('partials/scripts') %>

<script>
  function approveRequest() {
    if (!confirm('Êtes-vous sûr de vouloir valider cette demande ?\nLe client pourra alors passer sa commande.')) return;

    fetch('/admin/order-requests/<%= request.id %>/approve', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ requestId: <%= request.id %> })
    })
    .then(res => {
      if (!res.ok) {
        return res.json().then(err => { throw new Error(err.message || 'Erreur HTTP'); });
      }
      return res.json();
    })
    .then(data => {
      if (data.success) {
        alert('✅ Demande #' + <%= request.id %> + ' validée avec succès !\nLe client a été notifié par notification et peut maintenant passer sa commande.');
        window.location.reload();
      } else {
        alert('Erreur: ' + data.message);
      }
    })
    .catch(err => {
      console.error('Approve error:', err);
      alert('❌ Erreur lors de la validation de la demande: ' + err.message);
    });
  }

  function cancelRequest() {
    const reason = prompt('Veuillez entrer la raison de l\'annulation (optionnel) :');
    if (reason === null) return;

    if (!confirm('Êtes-vous sûr de vouloir annuler cette demande ?')) return;

    fetch('/admin/order-requests/<%= request.id %>/cancel', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ requestId: <%= request.id %>, reason })
    })
    .then(res => {
      if (!res.ok) {
        return res.json().then(err => { throw new Error(err.message || 'Erreur HTTP'); });
      }
      return res.json();
    })
    .then(data => {
      if (data.success) {
        alert('❌ Demande #' + <%= request.id %> + ' annulée avec succès !\nLe client a été notifié par notification.');
        window.location.reload();
      } else {
        alert('Erreur: ' + data.message);
      }
    })
    .catch(err => {
      console.error('Cancel error:', err);
      alert('❌ Erreur lors de l\'annulation de la demande: ' + err.message);
    });
  }
</script>
