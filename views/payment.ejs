<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Paiement</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <nav>
    <div class="nav-brand">
      <a href="/">
        <img src="/images/logo.jpg" alt="Myeva creation" class="nav-logo">
      </a>
    </div>

    <div class="nav-search">
      <form action="/" method="GET">
        <input type="text" name="search" placeholder="Rechercher des produits..." value="<%= typeof search !== 'undefined' ? search : '' %>">
        <button type="submit">🔍</button>
      </form>
    </div>

    <button class="menu-toggle" onclick="toggleMenu()">☰</button>
    <ul id="navMenu">
      <li><a href="/">Accueil</a></li>
      <% if (user) { %>
        <li><a href="/user/account">Compte</a></li>
        <li><a href="/cart">Panier</a></li>
        <li><a href="/auth/logout">Déconnexion</a></li>
      <% } else { %>
        <li><a href="/auth/login-page">Connexion</a></li>
        <li><a href="/auth/register-page">Inscription</a></li>
      <% } %>
    </ul>
  </nav>

  <script src="https://unpkg.com/lucide@latest"></script>

  <script>
    function toggleMenu() {
      const menu = document.getElementById('navMenu');
      menu.classList.toggle('active');
    }

    // Initialize Lucide icons after DOM is loaded
    document.addEventListener('DOMContentLoaded', function() {
      // Initialize Lucide icons
      if (typeof lucide !== 'undefined') {
        lucide.createIcons();
      }

      // Phone number formatting and validation
      const phoneInput = document.getElementById('phone');
      if (phoneInput) {
        // Format phone number as user types
        phoneInput.addEventListener('input', function(e) {
          let value = e.target.value.replace(/\D/g, ''); // Remove all non-digits
          if (value.length > 10) value = value.slice(0, 10); // Limit to 10 digits

          // Format as: 032 59 25 712
          if (value.length >= 3 && value.length < 6) {
            value = value.slice(0, 3) + ' ' + value.slice(3);
          } else if (value.length >= 6 && value.length < 8) {
            value = value.slice(0, 3) + ' ' + value.slice(3, 6) + ' ' + value.slice(6);
          } else if (value.length >= 8) {
            value = value.slice(0, 3) + ' ' + value.slice(3, 6) + ' ' + value.slice(6, 8) + ' ' + value.slice(8, 10);
          }

          e.target.value = value;
        });

        // Validate on form submit
        const form = phoneInput.closest('form');
        if (form) {
          form.addEventListener('submit', function(e) {
            const phoneValue = phoneInput.value.replace(/\D/g, '');
            if (phoneValue.length !== 10) {
              e.preventDefault();
              showToast('Veuillez entrer un numéro de téléphone valide (10 chiffres)', 'error');
              phoneInput.focus();
              return false;
            }
          });
        }
      }
    });

    // Toast notification function
    function showToast(message, type = 'info') {
      const container = document.getElementById('toastContainer') || createToastContainer();
      const toast = document.createElement('div');
      toast.className = `toast toast-${type}`;
      
      const icon = type === 'success' ? '✅' : type === 'error' ? '❌' : 'ℹ️';
      
      toast.innerHTML = `
        <div class="toast-icon">${icon}</div>
        <div class="toast-content">
          <p class="toast-message">${message}</p>
        </div>
        <button class="toast-close" onclick="hideToast(this.parentElement)">&times;</button>
      `;
      
      container.appendChild(toast);
      
      setTimeout(() => {
        hideToast(toast);
      }, 5000);
    }

    function hideToast(toast) {
      toast.classList.add('toast-hiding');
      setTimeout(() => {
        toast.remove();
      }, 300);
    }

    function createToastContainer() {
      const container = document.createElement('div');
      container.id = 'toastContainer';
      container.className = 'toast-container';
      document.body.appendChild(container);
      return container;
    }
  </script>

  <main>
    <div class="payment-container">
      <h2>Paiement</h2>

      <% if (typeof message !== 'undefined' && message) { %>
        <div class="<%= typeof success !== 'undefined' && success ? 'success-message' : 'error-message' %>">
          <%= message %>
        </div>
        <% if (typeof success !== 'undefined' && success) { %>
          <div style="text-align: center; margin-top: 2rem;">
            <a href="/" class="btn">Retourner à la boutique</a>
            <a href="/user/account" class="btn btn-primary">Voir mes commandes</a>
          </div>
        <% } %>
      <% } %>

      <% if (typeof cartItems !== 'undefined' && cartItems.length > 0 && (!message || !success)) { %>
        <div class="payment-content">
          <div class="payment-summary">
            <h3>Résumé de la commande</h3>

            <div class="summary-items">
              <% cartItems.forEach(item => { %>
                <div class="summary-item">
                  <div class="item-info">
                    <span class="item-name"><%= item.name %></span>
                    <span class="item-quantity">x<%= item.quantity %></span>
                  </div>
                  <span class="item-price">Ar<%= (item.price * item.quantity).toFixed(2) %></span>
                </div>
              <% }); %>
            </div>

            <div class="summary-subtotal">
              <span>Sous-total :</span>
              <span>Ar<%= total.toFixed(2) %></span>
            </div>

            <% if (typeof discountPercent !== 'undefined' && discountPercent > 0) { %>
            <div class="summary-discount">
              <span>
                <i data-lucide="gift" style="width: 16px; height: 16px; margin-right: 4px; vertical-align: middle;"></i>
                Réduction première commande (<%= discountPercent %>%) :
              </span>
              <span>- Ar<%= discountAmount.toFixed(2) %></span>
            </div>
            <% } %>

            <div class="summary-shipping">
              <span>
                <% if (shippingFee === 0) { %>
                  <i data-lucide="gift" style="width: 16px; height: 16px; margin-right: 4px; vertical-align: middle;"></i>
                  Frais de livraison (Offert dès 200 000 Ar) :
                <% } else { %>
                  Frais de livraison :
                <% } %>
              </span>
              <span class="<%= shippingFee === 0 ? 'shipping-free' : '' %>">
                <% if (shippingFee === 0) { %>
                  GRATUIT
                <% } else { %>
                  Ar<%= shippingFee.toFixed(2) %>
                <% } %>
              </span>
            </div>

            <div class="summary-total">
              <strong>Total à payer : Ar<%= (total - (typeof discountAmount !== 'undefined' ? discountAmount : 0) + shippingFee).toFixed(2) %></strong>
            </div>
          </div>

          <div class="payment-form-section">
            <h3>Informations de livraison</h3>
            <form method="POST" action="/checkout/process" class="payment-form">
              <div class="form-group">
                <label for="address">Adresse :</label>
                <input type="text" id="address" name="address" required placeholder="Ex: Lot IVB 12 Bis">
              </div>

              <div class="form-group">
                <label for="city">Ville :</label>
                <input type="text" id="city" name="city" required placeholder="Ex: Antananarivo">
              </div>

              <div class="form-group">
                <label for="state">Province :</label>
                <input type="text" id="state" name="state" required placeholder="Ex: Analamanga">
              </div>

              <div class="form-group">
                <label for="zip">Code postal :</label>
                <input type="text" id="zip" name="zip" required placeholder="Ex: 101">
              </div>

              <div class="form-group">
                <label for="phone">Numéro de téléphone :</label>
                <input type="tel" id="phone" name="phone" placeholder="032 59 25 712" pattern="[0-9\s]{10,13}" required>
                <small style="color: #666; font-size: 0.85rem;">Format attendu : 032 59 25 712</small>
              </div>

              <h3 style="margin-top: 2rem;">Méthode de paiement</h3>
              <div class="payment-methods">
                <div class="payment-method">
                  <div class="method-icon">💵</div>
                  <div class="method-info">
                    <h4>Paiement à la livraison</h4>
                    <p>Payez en espèces lorsque vous recevez votre commande</p>
                  </div>
                </div>
              </div>

              <div class="form-note">
                <i data-lucide="info" style="width: 20px; height: 20px; margin-right: 8px;"></i>
                En confirmant, vous créez votre commande. Le paiement se fera à la livraison.
              </div>

              <div class="form-actions">
                <a href="/checkout" class="btn btn-secondary">Retour</a>
                <button type="submit" class="btn btn-primary btn-confirm-payment">
                  Confirmer la commande
                </button>
              </div>
            </form>
          </div>
        </div>
      <% } %>
    </div>
  </main>

  <footer>
    <p>&copy; 2026 Shop. Tous droits réservés.</p>
  </footer>

  <style>
    .payment-container {
      max-width: 900px;
      margin: 2rem auto;
      padding: 0 1rem;
    }

    .payment-container h2 {
      text-align: center;
      margin-bottom: 0.5rem;
      color: #333;
    }

    .success-message {
      padding: 1.5rem;
      margin-bottom: 2rem;
      background-color: #d4edda;
      color: #155724;
      border: 1px solid #c3e6cb;
      border-radius: 8px;
      font-weight: 600;
      text-align: center;
    }

    .error-message {
      padding: 1.5rem;
      margin-bottom: 2rem;
      background-color: #f8d7da;
      color: #721c24;
      border: 1px solid #f5c6cb;
      border-radius: 8px;
      font-weight: 600;
      text-align: center;
    }

    .payment-content {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
      margin-top: 2rem;
    }

    .payment-summary {
      background: white;
      padding: 2rem;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      height: fit-content;
    }

    .summary-items {
      margin: 1.5rem 0;
      border-bottom: 1px solid #ddd;
      padding-bottom: 1rem;
    }

    .summary-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.75rem 0;
    }

    .item-info {
      display: flex;
      flex-direction: column;
    }

    .item-name {
      font-weight: 600;
      color: #333;
    }

    .item-quantity {
      font-size: 0.9rem;
      color: #666;
    }

    .item-price {
      font-weight: 600;
      color: #28a745;
    }

    .summary-subtotal,
    .summary-shipping {
      display: flex;
      justify-content: space-between;
      padding: 0.75rem 0;
      font-size: 1rem;
      color: #555;
    }

    .summary-discount {
      display: flex;
      justify-content: space-between;
      padding: 0.75rem 1rem;
      font-size: 1rem;
      color: #28a745;
      font-weight: 600;
      background: linear-gradient(135deg, rgba(40, 167, 69, 0.1) 0%, rgba(40, 167, 69, 0.05) 100%);
      border-radius: 6px;
      margin: 0.5rem 0;
      border: 1px dashed #28a745;
    }

    .summary-discount span:first-child {
      display: flex;
      align-items: center;
    }

    .summary-shipping {
      color: #28a745;
      font-weight: 600;
      background: linear-gradient(135deg, rgba(40, 167, 69, 0.05) 0%, rgba(40, 167, 69, 0.02) 100%);
      padding: 0.75rem 1rem;
      border-radius: 6px;
      margin: 0.5rem 0;
    }

    .summary-shipping .shipping-free {
      color: #28a745;
      font-weight: 700;
      font-size: 1.1rem;
    }

    .summary-total {
      padding: 1rem 0;
      text-align: right;
      font-size: 1.4rem;
      border-top: 2px solid #28a745;
      margin-top: 1rem;
      padding-top: 1rem;
      color: #28a745;
    }

    .payment-form-section {
      background: white;
      padding: 2rem;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    .payment-form-section h3 {
      margin-bottom: 1rem;
      color: #333;
      font-size: 1.2rem;
    }

    .form-group {
      margin-bottom: 1.25rem;
    }

    .form-group label {
      display: block;
      margin-bottom: 0.5rem;
      font-weight: 600;
      color: #333;
    }

    .form-group input {
      width: 100%;
      padding: 0.75rem;
      border: 1px solid #ddd;
      border-radius: 6px;
      font-size: 1rem;
    }

    .form-group input:focus {
      outline: none;
      border-color: #007bff;
      box-shadow: 0 0 0 3px rgba(0, 123, 255, 0.1);
    }

    .payment-methods {
      margin: 1.5rem 0;
    }

    .payment-method {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1.5rem;
      background: linear-gradient(135deg, #f0f8ff 0%, #ffffff 100%);
      border: 2px solid #007bff;
      border-radius: 8px;
    }

    .method-icon {
      font-size: 2.5rem;
    }

    .method-info h4 {
      margin: 0 0 0.25rem 0;
      color: #007bff;
    }

    .method-info p {
      margin: 0;
      color: #666;
      font-size: 0.9rem;
    }

    .payment-form {
      margin-top: 1.5rem;
    }

    .form-note {
      display: flex;
      align-items: center;
      padding: 1rem;
      background: #fff3cd;
      border: 1px solid #ffc107;
      border-radius: 6px;
      color: #856404;
      margin-bottom: 1.5rem;
    }

    .form-actions {
      display: flex;
      gap: 1rem;
    }

    .form-actions .btn {
      flex: 1;
      text-align: center;
      padding: 0.8rem;
    }

    .btn-secondary {
      background-color: #6c757d;
      color: white;
      text-decoration: none;
    }

    .btn-secondary:hover {
      background-color: #5a6268;
    }

    .btn-confirm-payment {
      background-color: #28a745;
      flex: 2;
    }

    .btn-confirm-payment:hover {
      background-color: #218838;
    }

    @media (max-width: 768px) {
      .payment-content {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <%- include('partials/footer') %>
</body>
</html>
