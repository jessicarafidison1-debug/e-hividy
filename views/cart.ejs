<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Panier d'achat</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <nav>
    <div class="nav-brand">
      <a href="/">
        <img src="/images/logo.jpg" alt="Myeva creation" class="nav-logo">
      </a>
    </div>
    
    <div class="nav-search">
      <form action="/" method="GET">
        <input type="text" name="search" placeholder="Rechercher des produits..." value="<%= typeof search !== 'undefined' ? search : '' %>">
        <button type="submit">🔍</button>
      </form>
    </div>

    <button class="menu-toggle" onclick="toggleMenu()">☰</button>
    <ul id="navMenu">
      <li><a href="/">Accueil</a></li>
      <% if (user) { %>
        <li><a href="/user/account">Compte</a></li>
        <li><a href="/cart">Panier</a></li>
        <li><a href="/auth/logout">Déconnexion</a></li>
      <% } else { %>
        <li><a href="/auth/login-page">Connexion</a></li>
        <li><a href="/auth/register-page">Inscription</a></li>
      <% } %>
    </ul>
  </nav>

  <script>
    function toggleMenu() {
      const menu = document.getElementById('navMenu');
      menu.classList.toggle('active');
    }
  </script>

  <main>
    <h2>Panier d'achat</h2>
    
    <% if (cartItems.length > 0) { %>
      <table>
        <thead>
          <tr>
            <th>Image</th>
            <th>Produit</th>
            <th>Prix</th>
            <th>Quantité</th>
            <th>Sous-total</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% cartItems.forEach(item => { %>
            <tr>
              <td>
                <div class="cart-item-image">
                  <% if (item.image) { %>
                    <img src="<%= item.image %>" alt="<%= item.name %>">
                  <% } else { %>
                    <span class="placeholder-icon">📦</span>
                  <% } %>
                </div>
              </td>
              <td><%= item.name %></td>
              <td>Ar<%= item.price %></td>
              <td><%= item.quantity %></td>
              <td>Ar<%= (item.price * item.quantity).toFixed(2) %></td>
              <td>
                <button class="remove-btn" onclick="removeItem(<%= item.id %>)">Supprimer</button>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
      
      <div class="cart-summary">
        <h3>Total : Ar<%= total.toFixed(2) %></h3>
        <a href="/" class="btn">Continuer les achats</a>
        <a href="/checkout" class="btn btn-primary">Procéder au paiement</a>
      </div>
    <% } else { %>
      <p class="empty-cart">Votre panier est vide.</p>
      <a href="/" class="btn">Continuer les achats</a>
    <% } %>
  </main>

  <script>
    async function removeItem(cartId) {
      if (confirm('Êtes-vous sûr de vouloir supprimer cet article ?')) {
        try {
          const response = await fetch('/cart/remove/' + cartId, {
            method: 'POST'
          });
          
          if (response.ok) {
            location.reload();
          } else {
            alert('Erreur lors de la suppression de l\'article');
          }
        } catch (error) {
          console.error('Erreur:', error);
          alert('Erreur lors de la suppression de l\'article');
        }
      }
    }
  </script>

  <style>
    .remove-btn {
      background-color: #dc3545;
      padding: 0.3rem 0.6rem;
      font-size: 0.9rem;
    }
    
    .remove-btn:hover {
      background-color: #c82333;
    }
    
    .cart-summary {
      margin-top: 2rem;
      padding: 1.5rem;
      background: white;
      border-radius: 8px;
      text-align: right;
    }
    
    .btn {
      display: inline-block;
      margin-left: 1rem;
      padding: 0.7rem 1.5rem;
      background-color: #007bff;
      color: white;
      text-decoration: none;
      border-radius: 4px;
      cursor: pointer;
    }
    
    .btn:hover {
      background-color: #0056b3;
    }
    
    .btn-primary {
      background-color: #28a745;
    }
    
    .btn-primary:hover {
      background-color: #218838;
    }
    
    .empty-cart {
      text-align: center;
      padding: 2rem;
      font-size: 1.2rem;
      color: #666;
    }
  </style>
</body>
</html>
