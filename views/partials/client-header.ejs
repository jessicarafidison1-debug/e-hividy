<nav>
  <div class="nav-brand">
    <a href="/">
      <img src="/images/logo.jpg" alt="Myeva creation" class="nav-logo">
    </a>
  </div>

  <div class="nav-search">
    <form action="/" method="GET">
      <input type="text" name="search" placeholder="Rechercher des produits..." value="<%= typeof search !== 'undefined' ? search : '' %>">
      <button type="submit">🔍</button>
    </form>
  </div>

  <button class="menu-toggle" onclick="toggleMenu()">☰</button>
  <ul id="navMenu">
    <li><a href="/">Accueil</a></li>
    <% if (typeof user !== 'undefined' && user) { %>
      <li>
        <a href="/user/account" style="position: relative; display: inline-block;">
          Compte
          <span id="accountNotificationBadge" style="display: none; position: absolute; top: -5px; right: -8px; background: #dc3545; color: white; border-radius: 50%; width: 18px; height: 18px; font-size: 11px; font-weight: bold; text-align: center; line-height: 18px; border: 2px solid white;"></span>
        </a>
      </li>
      <li>
        <a href="/cart">Panier</a>
      </li>
      <li class="notification-item">
        <a href="javascript:void(0)" onclick="openNotifications()" style="position: relative; display: inline-block; padding: 0.5rem;">
          🔔 Notifications
          <span id="notificationBadge" style="display: none; position: absolute; top: 0; right: 0; background: #dc3545; color: white; border-radius: 50%; padding: 2px 6px; font-size: 10px; font-weight: bold; min-width: 18px; text-align: center; border: 2px solid white;"></span>
        </a>
      </li>
      <li><a href="/auth/logout">Déconnexion</a></li>
    <% } else { %>
      <li><a href="/auth/login-page">Connexion</a></li>
      <li><a href="/auth/register-page">Inscription</a></li>
    <% } %>
  </ul>
</nav>

<!-- Toast Notification Container -->
<div id="toastContainer" class="toast-container"></div>

<!-- Notifications Modal -->
<div id="notificationsModal" style="display: none; position: fixed; top: 70px; right: 20px; width: 380px; max-height: 500px; background: white; border-radius: 12px; box-shadow: 0 10px 40px rgba(0,0,0,0.2); z-index: 10000; overflow: hidden;">
  <div style="padding: 1rem; border-bottom: 1px solid #e5e7eb; display: flex; justify-content: space-between; align-items: center; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
    <h3 style="margin: 0; color: white; font-size: 1rem;">🔔 Notifications</h3>
    <button onclick="closeNotifications()" style="background: none; border: none; color: white; cursor: pointer; font-size: 1.25rem; padding: 0.25rem;">&times;</button>
  </div>
  <div id="notificationsContent" style="padding: 0; overflow-y: auto; max-height: 420px;">
    <div style="padding: 2rem; text-align: center; color: #6b7280;">
      <p style="margin: 0;">Chargement...</p>
    </div>
  </div>
</div>

<script>
  function toggleMenu() {
    const menu = document.getElementById('navMenu');
    menu.classList.toggle('active');
  }

  let notificationCheckInterval;
  let lastNotificationId = null;

  // Show toast notification
  function showToast(title, message, type = 'info') {
    const container = document.getElementById('toastContainer');
    const toast = document.createElement('div');
    toast.className = `toast toast-${type}`;

    const icon = type === 'success' ? '✅' : type === 'error' ? '❌' : '📦';

    toast.innerHTML = `
      <div class="toast-icon">${icon}</div>
      <div class="toast-content">
        <div class="toast-title">${title}</div>
        <p class="toast-message">${message}</p>
      </div>
      <button class="toast-close" onclick="hideToast(this.parentElement)">&times;</button>
    `;

    container.appendChild(toast);

    // Auto-hide after 5 seconds
    setTimeout(() => {
      hideToast(toast);
    }, 5000);
  }

  function hideToast(toast) {
    toast.classList.add('toast-hiding');
    setTimeout(() => {
      toast.remove();
    }, 300);
  }

  function openNotifications() {
    const modal = document.getElementById('notificationsModal');
    modal.style.display = 'block';
    loadNotifications();
    // Mark as read and clear badge
    document.getElementById('notificationBadge').style.display = 'none';
    document.getElementById('accountNotificationBadge').style.display = 'none';
  }

  function closeNotifications() {
    document.getElementById('notificationsModal').style.display = 'none';
  }

  function loadNotifications() {
    fetch('/user/notifications')
      .then(res => res.json())
      .then(data => {
        if (data.success && data.notifications.length > 0) {
          let html = '';
          data.notifications.forEach(notif => {
            const typeIcon = notif.type === 'order_approved' ? '✅' :
                             notif.type === 'order_cancelled' ? '❌' : '📦';
            const typeClass = notif.type === 'order_approved' ? 'notif-success' :
                              notif.type === 'order_cancelled' ? 'notif-danger' : 'notif-info';
            html += `
              <div style="padding: 1rem; border-bottom: 1px solid #f3f4f6; display: flex; gap: 0.75rem; align-items: flex-start;">
                <div style="font-size: 1.5rem; flex-shrink: 0;">${typeIcon}</div>
                <div style="flex: 1; min-width: 0;">
                  <p style="margin: 0 0 0.25rem 0; font-weight: 600; color: #111827; font-size: 0.9375rem;">${notif.title}</p>
                  <p style="margin: 0 0 0.5rem 0; color: #6b7280; font-size: 0.8125rem;">${notif.message}</p>
                  <p style="margin: 0; color: #9ca3af; font-size: 0.75rem;">${new Date(notif.created_at).toLocaleString('fr-FR')}</p>
                </div>
              </div>
            `;
          });
          document.getElementById('notificationsContent').innerHTML = html;
        } else {
          document.getElementById('notificationsContent').innerHTML = `
            <div style="padding: 2rem; text-align: center; color: #6b7280;">
              <p style="margin: 0;">Aucune notification</p>
            </div>
          `;
        }
      })
      .catch(err => {
        console.error(err);
        document.getElementById('notificationsContent').innerHTML = `
          <div style="padding: 2rem; text-align: center; color: #dc3545;">
            <p style="margin: 0;">Erreur de chargement</p>
          </div>
        `;
      });
  }

  function checkNotifications() {
    fetch('/user/api/notification-count')
      .then(res => res.json())
      .then(data => {
        updateNotificationBadge(data.count);
      })
      .catch(err => console.error(err));

    // Check for new notifications and show toast
    fetch('/user/api/latest-notification')
      .then(res => res.json())
      .then(data => {
        if (data.success && data.notification) {
          // Only show toast if this is a new notification we haven't shown before
          if (lastNotificationId !== data.notification.id) {
            const type = data.notification.type === 'order_approved' ? 'success' :
                         data.notification.type === 'order_cancelled' ? 'error' : 'info';
            showToast(data.notification.title, data.notification.message, type);
            lastNotificationId = data.notification.id;
          }
        }
      })
      .catch(err => console.error(err));
  }

  function updateNotificationBadge(count) {
    const badge = document.getElementById('notificationBadge');
    const accountBadge = document.getElementById('accountNotificationBadge');

    if (count > 0) {
      badge.style.display = 'inline-block';
      badge.textContent = Math.min(count, 99);

      // Show red dot on account button
      accountBadge.style.display = 'block';
    } else {
      badge.style.display = 'none';
      accountBadge.style.display = 'none';
    }
  }

  // Check notifications every 30 seconds
  if (typeof user !== 'undefined' && user) {
    // Initial check
    checkNotifications();
    notificationCheckInterval = setInterval(checkNotifications, 30000);
  }

  // Close modal when clicking outside
  window.onclick = function(event) {
    const modal = document.getElementById('notificationsModal');
    if (event.target === modal) {
      closeNotifications();
    }
  }
</script>

<style>
  .notification-item {
    position: relative;
  }
</style>
